		"title": "Onboarding Template",
		"post_content": "<!-- wp:cover {\"overlayColor\":\"leco-cp-primary\",\"isUserOverlayColor\":true,\"contentPosition\":\"center center\",\"isDark\":false,\"tagName\":\"header\",\"metadata\":{\"categories\":[\"leco-client-portal\"],\"patternName\":\"leco-cp/header\",\"name\":\"Header\"},\"align\":\"full\",\"className\":\"title-section\"} -->\n<header class=\"wp-block-cover alignfull is-light title-section\"><span aria-hidden=\"true\" class=\"wp-block-cover__background has-leco-cp-primary-background-color has-background-dim-100 has-background-dim\"></span><div class=\"wp-block-cover__inner-container\"><!-- wp:group {\"style\":{\"spacing\":{\"blockGap\":\"var:preset|spacing|40\"}},\"layout\":{\"type\":\"flex\",\"orientation\":\"vertical\",\"justifyContent\":\"center\",\"flexWrap\":\"nowrap\"}} -->\n<div class=\"wp-block-group\"><!-- wp:leco-cp/header-logo /-->\n\n<!-- wp:post-title /-->\n\n<!-- wp:navigation {\"ref\":\"{{navigation:leco-cp-navigation}}\"} /--></div>\n<!-- /wp:group --></div></header>\n<!-- /wp:cover -->\n\n<!-- wp:group {\"className\":\"content-section\",\"layout\":{\"type\":\"constrained\"}} -->\n<div class=\"wp-block-group content-section\"><!-- wp:heading {\"level\":3} -->\n<h3 class=\"wp-block-heading\">Welcome to your portal</h3>\n<!-- /wp:heading -->\n\n<!-- wp:paragraph -->\n<p>This is where everything for your project lives. Start with your tasks below. The other sections are here whenever you need them.</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:paragraph -->\n<p><strong>Where to start:</strong></p>\n<!-- /wp:paragraph -->\n\n<!-- wp:list {\"ordered\":true} -->\n<ol class=\"wp-block-list\"><!-- wp:list-item -->\n<li>Read \"How we work\" so you know what to expect.</li>\n<!-- /wp:list-item -->\n\n<!-- wp:list-item -->\n<li>Work through your tasks: sign the agreement, answer a few questions, and upload your assets.</li>\n<!-- /wp:list-item -->\n\n<!-- wp:list-item -->\n<li>Book your kickoff call when you are ready.</li>\n<!-- /wp:list-item --></ol>\n<!-- /wp:list -->\n\n<!-- wp:paragraph -->\n<p>Your point of contact is <strong>[contact name]</strong>. Questions? Email <a href=\"mailto:[your email]\" data-type=\"mailto\" data-id=\"mailto:[your email]\">[your email]</a>.</p>\n<!-- /wp:paragraph --></div>\n<!-- /wp:group -->\n\n<!-- wp:group {\"className\":\"callout-blue content-section\",\"layout\":{\"type\":\"constrained\"}} -->\n<div class=\"wp-block-group callout-blue content-section\"><!-- wp:paragraph -->\n<p><strong>Setup note:</strong> Replace the bracketed details with your client's name, your point of contact, and a start date. Delete this note before sharing.</p>\n<!-- /wp:paragraph --></div>\n<!-- /wp:group -->\n\n<!-- wp:leco-cp/general-information {\"insertBlocks\":false,\"metadata\":{\"categories\":[\"leco-client-portal\"],\"patternName\":\"leco-cp/general-information\",\"name\":\"General Information\"}} /-->\n\n<!-- wp:leco-cp/project-status {\"metadata\":{\"categories\":[\"leco-client-portal\"],\"patternName\":\"leco-cp/project-status\",\"name\":\"Show project status\"}} -->\n<div class=\"wp-block-leco-cp-project-status alignwide leco-cp-cols-3 leco-cp-container\"><!-- wp:leco-cp/project-status-block {\"value\":\"[Client name]\",\"label\":\"Client\",\"backgroundColor\":\"leco-cp-secondary\"} /-->\n\n<!-- wp:leco-cp/project-status-block {\"value\":\"[Point of contact]\",\"label\":\"Point of contact\"} /-->\n\n<!-- wp:leco-cp/project-status-block {\"value\":\"[Start date]\",\"label\":\"Start date\",\"backgroundColor\":\"leco-cp-tertiary\"} /--></div>\n<!-- /wp:leco-cp/project-status -->\n\n<!-- wp:group {\"metadata\":{\"categories\":[\"leco-client-portal\"],\"patternName\":\"leco-cp/phases-blocks\",\"name\":\"Phases Boxes\"},\"align\":\"full\",\"className\":\"main-content\",\"layout\":{\"type\":\"constrained\",\"contentSize\":\"1024px\"}} -->\n<div class=\"wp-block-group alignfull main-content\"><!-- wp:leco-cp/search-bar {\"className\":\"wp-block-leco-cp-search-bar\"} /-->\n\n<!-- wp:leco-cp/phases {\"title\":\"Getting Started\",\"description\":\"Start here. Get to know how we work and what to expect\",\"phase\":\"PART 1\",\"uid\":0} -->\n<div class=\"leco-cp-cols-3 leco-cp-container leco-cp-phases-container\"><!-- wp:leco-cp/modules {\"uid\":0,\"phaseID\":\"8c03cc8f-5710-4cb6-8f02-dff0fac1a478\",\"icon\":\"heart\",\"moduleType\":\"module-content-page\",\"openTab\":\"content-page\",\"moduleContentPage\":\"{{content_page:welcome-2}}\"} -->\n<div><span class=\"title\" style=\"color:#3c5063\">Welcome</span><span class=\"description\">A two-minute walkthrough of how this portal works.</span></div>\n<!-- /wp:leco-cp/modules -->\n\n<!-- wp:leco-cp/modules {\"uid\":1,\"phaseID\":\"c904ce2e-a902-4f93-9da2-114ce1cec867\",\"icon\":\"compass\",\"moduleType\":\"module-content-page\",\"openTab\":\"content-page\",\"moduleContentPage\":\"{{content_page:how-we-work-2}}\"} -->\n<div><span class=\"title\" style=\"color:#3c5063\">How We Work</span><span class=\"description\">Our process, communication, and revisions, in brief.</span></div>\n<!-- /wp:leco-cp/modules --></div>\n<!-- /wp:leco-cp/phases -->\n\n<!-- wp:leco-cp/phases {\"title\":\"Your Tasks\",\"description\":\"The bits we need from you to get started. Work through them in any order.\",\"phase\":\"PART 2\",\"uid\":1} -->\n<div class=\"leco-cp-cols-3 leco-cp-container leco-cp-phases-container\"><!-- wp:leco-cp/modules {\"uid\":3,\"phaseID\":\"0ca5ba05-a023-4eed-ae37-f2d4dbb43e52\",\"icon\":\"quill\",\"openTab\":\"link\",\"dueDate\":true,\"moduleDueDate\":\"2031-04-27T11:02:00\",\"showMarkAsComplete\":\"show\",\"moduleLinks\":[{\"linkTitle\":\"Review and sign your contract\",\"linkUrl\":\"contact-link\"},{\"linkUrl\":\"contract-download-link\",\"linkTitle\":\"Download a copy\"}],\"textBelow\":\"\\u003cstrong\\u003eSetup note:\\u003c/strong\\u003e Client Portal links to your contract, it does not do the signing. Most tools (DocuSign, Adobe Sign) give you a shareable link, add it to the button. Prefer email? Sign your usual way and upload the signed PDF with the Files module.\",\"showTextBelow\":true} -->\n<div><span class=\"title\" style=\"color:#3c5063\">Contract</span><span class=\"description\">Review and sign the project agreement.</span></div>\n<!-- /wp:leco-cp/modules -->\n\n<!-- wp:leco-cp/modules {\"uid\":4,\"phaseID\":\"7b65ab8f-d886-44aa-ade3-ab49418271d8\",\"icon\":\"lock\",\"openTab\":\"link\",\"dueDate\":true,\"moduleDueDate\":\"2031-04-27T11:03:00\",\"showMarkAsComplete\":\"show\",\"moduleLinks\":[{\"linkTitle\":\"Open the NDA\",\"linkUrl\":\"nda-link\"},{\"linkUrl\":\"nda-link\",\"linkTitle\":\"Download completed NDA\"}],\"textBelow\":\"\\u003cstrong\\u003eSetup note:\\u003c/strong\\u003e Same idea as the contract above. Link your NDA from your signing tool, or upload a PDF. Remove this module if you do not use an NDA.\",\"showTextBelow\":true} -->\n<div><span class=\"title\" style=\"color:#3c5063\">NDA</span><span class=\"description\">A simple mutual non-disclosure agreement to sign.</span></div>\n<!-- /wp:leco-cp/modules -->\n\n<!-- wp:leco-cp/modules {\"uid\":13,\"phaseID\":\"e6cf5259-9fb3-41b5-9242-16716f937f4b\",\"icon\":\"clipboard\",\"moduleType\":\"module-content-page\",\"openTab\":\"content-page\",\"showMarkAsComplete\":\"show\",\"moduleContentPage\":\"{{content_page:about-your-business}}\"} -->\n<div><span class=\"title\" style=\"color:#3c5063\">About Your Business</span><span class=\"description\">A few questions to get to know you.</span></div>\n<!-- /wp:leco-cp/modules -->\n\n<!-- wp:leco-cp/modules {\"uid\":14,\"phaseID\":\"1c09a1c3-03c7-486a-bb20-f7cb17690751\",\"moduleType\":\"module-client-uploads\",\"showMarkAsComplete\":\"show\",\"textAbove\":\"\\u003cstrong\\u003eSetup note:\\u003c/strong\\u003e Use the Client Upload module so clients add files directly. In this public demo the upload area is not shown.\",\"showTextAbove\":true} -->\n<div><span class=\"title\" style=\"color:#3c5063\">Upload Your Assets</span><span class=\"description\">Your logo and any brand assets you'd like us to use.</span></div>\n<!-- /wp:leco-cp/modules -->\n\n<!-- wp:leco-cp/modules {\"uid\":6,\"phaseID\":\"01b1ee2e-9efd-43c1-8900-fe2a18703bd6\",\"icon\":\"calendar\",\"openTab\":\"link\",\"showMarkAsComplete\":\"show\",\"moduleLinks\":[{\"linkTitle\":\"Book your kick-off call\",\"linkUrl\":\"call-link\"},{\"linkUrl\":\"call-link\",\"linkTitle\":\"Book a review\"}],\"textBelow\":\"\\u003cstrong\\u003eSetup note:\\u003c/strong\\u003e Link your scheduling tool (Calendly, SavvyCal) so clients book without the back-and-forth.\",\"showTextBelow\":true} -->\n<div><span class=\"title\" style=\"color:#3c5063\">Book Your Kickoff Call</span><span class=\"description\">Grab a time that suits you and we'll get started.</span></div>\n<!-- /wp:leco-cp/modules -->\n\n<!-- wp:leco-cp/modules {\"uid\":5,\"phaseID\":\"e0d46dc2-c3ee-413a-aba1-40f6d1f48804\",\"icon\":\"cost\",\"openTab\":\"link\",\"moduleLinks\":[{\"linkTitle\":\"View and pay your outstanding invoices\",\"linkUrl\":\"invoice-link\"},{\"linkUrl\":\"invoice-link\",\"linkTitle\":\"Download your invoice receipts\"}],\"textBelow\":\"\\u003cstrong\\u003eSetup note:\\u003c/strong\\u003e Link to wherever you invoice. Drop in a payment link (Stripe, most invoicing tools provide one) or upload a PDF.\",\"showTextBelow\":true} -->\n<div><span class=\"title\" style=\"color:#3c5063\">Invoices</span><span class=\"description\">View and pay your project invoices.</span></div>\n<!-- /wp:leco-cp/modules --></div>\n<!-- /wp:leco-cp/phases -->\n\n<!-- wp:leco-cp/phases {\"title\":\"Useful Resources\",\"description\":\"Ways to reach us and a few things to make the project easier.\",\"phase\":\"PART 3\",\"uid\":2} -->\n<div class=\"leco-cp-cols-3 leco-cp-container leco-cp-phases-container\"><!-- wp:leco-cp/modules {\"uid\":7,\"phaseID\":\"29d47fb8-3a6d-47c2-a228-fbfd1501ca78\",\"icon\":\"chat\",\"openTab\":\"link\",\"moduleLinks\":[{\"linkTitle\":\"Your private Slack workspace\",\"linkUrl\":\"slack-link\"},{\"linkUrl\":\"slack-link\",\"linkTitle\":\"Join our public channel\"}],\"textBelow\":\"Slack is best for quick questions and day-to-day updates. For approvals or scope changes, please use email so we have a clear record.\\n\\n\\u003cstrong\\u003eSetup note:\\u003c/strong\\u003e Swap in your own invite, or your preferred chat tool. Remove if you do not use one.\",\"showTextBelow\":true} -->\n<div><span class=\"title\" style=\"color:#3c5063\">Join Our Slack</span><span class=\"description\">The quickest way to reach us day to day.</span></div>\n<!-- /wp:leco-cp/modules -->\n\n<!-- wp:leco-cp/modules {\"uid\":8,\"phaseID\":\"443dc2e7-d8aa-4334-8b2b-a644fdad2e21\",\"icon\":\"help\",\"moduleType\":\"module-content-page\",\"openTab\":\"content-page\",\"moduleContentPage\":\"{{content_page:help-and-faq-2}}\"} -->\n<div><span class=\"title\" style=\"color:#3c5063\">Help and FAQ</span><span class=\"description\">Answers to the questions clients ask most.</span></div>\n<!-- /wp:leco-cp/modules -->\n\n<!-- wp:leco-cp/modules {\"uid\":9,\"phaseID\":\"9bf857bf-2cbd-43b7-8904-2af68b26610d\",\"icon\":\"settings\",\"openTab\":\"link\",\"moduleLinks\":[{\"linkTitle\":\"Figma\",\"linkUrl\":\"figma-link\"},{\"linkTitle\":\"Loom\",\"linkUrl\":\"loom-link\"},{\"linkTitle\":\"Notion\",\"linkUrl\":\"notion-link\"},{\"linkTitle\":\"Google Drive\",\"linkUrl\":\"google-link\"}],\"textBelow\":\"\\u003cstrong\\u003eSetup note:\\u003c/strong\\u003e List only the tools your client needs a login for. Fewer is better.\",\"showTextBelow\":true} -->\n<div><span class=\"title\" style=\"color:#3c5063\">Recommended Tools</span><span class=\"description\">The handful of tools we use to work together.</span></div>\n<!-- /wp:leco-cp/modules --></div>\n<!-- /wp:leco-cp/phases -->\n\n<!-- wp:leco-cp/phases {\"title\":\"Add-Ons\",\"description\":\"Optional extras you can add to your project at any point.\",\"phase\":\"PART 4\",\"uid\":3} -->\n<div class=\"leco-cp-cols-3 leco-cp-container leco-cp-phases-container\"><!-- wp:leco-cp/modules {\"uid\":11,\"phaseID\":\"386f21ce-717f-487a-b7c0-b14e4ab52ae3\",\"icon\":\"headphones\",\"openTab\":\"link\",\"moduleLinks\":[{\"linkTitle\":\"Learn more\",\"linkUrl\":\"more-info-link\"},{\"linkUrl\":\"purchase-link\",\"linkTitle\":\"Subscribe to a care plan\"}],\"textBelow\":\"We keep your site updated, backed up, and secure, with a set allowance of small changes each month. Billed monthly, cancel any time.\\n\\n\\u003cstrong\\u003eSetup note:\\u003c/strong\\u003e Link to your care plan page or checkout. This is your easiest recurring upsell, so it is worth keeping here.\",\"showTextBelow\":true} -->\n<div><span class=\"title\" style=\"color:#3c5063\">Website Care Plan</span><span class=\"description\">Updates, backups, and small tweaks, handled monthly.</span></div>\n<!-- /wp:leco-cp/modules -->\n\n<!-- wp:leco-cp/modules {\"uid\":10,\"phaseID\":\"fd37671a-cbf4-4d46-8f0f-4b63e98dbd34\",\"icon\":\"loupe\",\"openTab\":\"link\",\"moduleLinks\":[{\"linkTitle\":\"Learn more\",\"linkUrl\":\"more-info-link\"},{\"linkUrl\":\"purchase-link\",\"linkTitle\":\"Purchase a teardown\"}],\"textBelow\":\"\\u003cstrong\\u003eSetup note:\\u003c/strong\\u003e Link to your teardown service page, or remove if you do not offer one.\",\"showTextBelow\":true} -->\n<div><span class=\"title\" style=\"color:#3c5063\">Landing Page Teardown</span><span class=\"description\">A recorded, page-by-page critique of one landing page.</span></div>\n<!-- /wp:leco-cp/modules -->\n\n<!-- wp:leco-cp/modules {\"uid\":12,\"phaseID\":\"30b64d29-76bb-4a45-9bba-3729fa467c87\",\"icon\":\"lightbulb\",\"openTab\":\"link\",\"moduleLinks\":[{\"linkTitle\":\"Learn more\",\"linkUrl\":\"more-info-link\"},{\"linkUrl\":\"purchase-link\",\"linkTitle\":\"Book a power hour\"}],\"textBelow\":\"\\u003cstrong\\u003eSetup note:\\u003c/strong\\u003e Link to your booking page, or remove.\",\"showTextBelow\":true} -->\n<div><span class=\"title\" style=\"color:#3c5063\">Power Hour</span><span class=\"description\">Sixty focused minutes on whatever is most pressing.</span></div>\n<!-- /wp:leco-cp/modules --></div>\n<!-- /wp:leco-cp/phases --></div>\n<!-- /wp:group -->\n\n<!-- wp:group {\"metadata\":{\"categories\":[\"leco-client-portal\"],\"patternName\":\"leco-cp/call-to-action\",\"name\":\"Call To Action\"},\"align\":\"full\",\"className\":\"cta-section\",\"backgroundColor\":\"leco-cp-primary\",\"layout\":{\"type\":\"flex\",\"orientation\":\"vertical\",\"justifyContent\":\"center\"}} -->\n<div class=\"wp-block-group alignfull cta-section has-leco-cp-primary-background-color has-background\"><!-- wp:paragraph {\"className\":\"has-large-font-size\",\"style\":{\"spacing\":{\"margin\":{\"bottom\":\"2rem\"}},\"typography\":{\"textAlign\":\"center\"}},\"fontSize\":\"x-large\"} -->\n<p class=\"has-text-align-center has-large-font-size has-x-large-font-size\" style=\"margin-bottom:2rem\">Need a hand with anything?</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:buttons {\"layout\":{\"type\":\"flex\",\"justifyContent\":\"center\"}} -->\n<div class=\"wp-block-buttons\"><!-- wp:button -->\n<div class=\"wp-block-button\"><a class=\"wp-block-button__link wp-element-button\">Get in touch</a></div>\n<!-- /wp:button --></div>\n<!-- /wp:buttons --></div>\n<!-- /wp:group -->\n\n<!-- wp:group {\"metadata\":{\"categories\":[\"leco-client-portal\"],\"patternName\":\"leco-cp/footer-contact\",\"name\":\"Footer Contact\"},\"align\":\"full\",\"className\":\"contacts\",\"backgroundColor\":\"leco-cp-tertiary\",\"layout\":{\"type\":\"constrained\"}} -->\n<div class=\"wp-block-group alignfull contacts has-leco-cp-tertiary-background-color has-background\"><!-- wp:list {\"fontSize\":\"small\"} -->\n<ul class=\"wp-block-list has-small-font-size\"><!-- wp:list-item -->\n<li>[your phone]</li>\n<!-- /wp:list-item -->\n\n<!-- wp:list-item -->\n<li>[your email]</li>\n<!-- /wp:list-item -->\n\n<!-- wp:list-item -->\n<li>Powered by <a href=\"http://www.client-portal.io/\">Client Portal</a></li>\n<!-- /wp:list-item --></ul>\n<!-- /wp:list --></div>\n<!-- /wp:group -->\n\n<!-- wp:paragraph -->\n<p></p>\n<!-- /wp:paragraph -->\n",
