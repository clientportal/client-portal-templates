		{
			"ref_slug": "welcome-2",
			"title": "Welcome",
			"post_content": "<!-- wp:heading -->\n<h2 class=\"wp-block-heading\">Welcome to your portal</h2>\n<!-- /wp:heading -->\n\n<!-- wp:paragraph -->\n<p>This is a two-minute walkthrough of how this portal works and where to find things.</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:group {\"className\":\"callout-blue\"} -->\n<div class=\"wp-block-group callout-blue\"><!-- wp:paragraph -->\n<p><strong>Setup note:</strong> Record a short Loom walking through the portal and add it with the Embed module, or keep a written intro here. Delete this note before sharing.</p>\n<!-- /wp:paragraph --></div>\n<!-- /wp:group -->\n",
			"post_name": "welcome-2",
			"meta": []
		},
		{
			"ref_slug": "how-we-work-2",
			"title": "How we work",
			"post_content": "<!-- wp:heading -->\n<h2 class=\"wp-block-heading\">How we work</h2>\n<!-- /wp:heading -->\n\n<!-- wp:heading {\"level\":3} -->\n<h3 class=\"wp-block-heading\">Our process</h3>\n<!-- /wp:heading -->\n\n<!-- wp:paragraph -->\n<p>[One line on how a project runs, start to finish.]</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:heading {\"level\":3} -->\n<h3 class=\"wp-block-heading\">How we communicate</h3>\n<!-- /wp:heading -->\n\n<!-- wp:paragraph -->\n<p>[One line on where you talk and how fast you reply.]</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:heading {\"level\":3} -->\n<h3 class=\"wp-block-heading\">Revisions</h3>\n<!-- /wp:heading -->\n\n<!-- wp:paragraph -->\n<p>[One line on how many rounds of revisions are included.]</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:group {\"className\":\"callout-blue\"} -->\n<div class=\"wp-block-group callout-blue\"><!-- wp:paragraph -->\n<p><strong>Setup note:</strong> Replace each section with how you actually work. Clients read this once, so keep it short. Delete this note before sharing.</p>\n<!-- /wp:paragraph --></div>\n<!-- /wp:group -->\n",
			"post_name": "how-we-work-2",
			"meta": []
		},
		{
			"ref_slug": "about-your-business",
			"title": "About your business",
			"post_content": "<!-- wp:heading -->\n<h2 class=\"wp-block-heading\">About your business</h2>\n<!-- /wp:heading -->\n\n<!-- wp:paragraph -->\n<p>A few questions to help us get to know you.</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:group {\"className\":\"callout-blue\"} -->\n<div class=\"wp-block-group callout-blue\"><!-- wp:paragraph -->\n<p><strong>Setup note:</strong> Embed your intake form (Typeform, Fluent Forms, Gravity Forms) with the Embed module, or link out with a button. Listing the questions as plain text works too. Delete this note before sharing.</p>\n<!-- /wp:paragraph --></div>\n<!-- /wp:group -->\n",
			"post_name": "about-your-business",
			"meta": []
		},
		{
			"ref_slug": "help-and-faq-2",
			"title": "Help and FAQ",
			"post_content": "<!-- wp:heading -->\n<h2 class=\"wp-block-heading\">Help and FAQ</h2>\n<!-- /wp:heading -->\n\n<!-- wp:heading {\"level\":3} -->\n<h3 class=\"wp-block-heading\">[Question clients ask most]</h3>\n<!-- /wp:heading -->\n\n<!-- wp:paragraph -->\n<p>[Your answer.]</p>\n<!-- /wp:paragraph -->\n\n<!-- wp:group {\"className\":\"callout-blue\"} -->\n<div class=\"wp-block-group callout-blue\"><!-- wp:paragraph -->\n<p><strong>Setup note:</strong> Add the five or six questions clients actually ask you. This cuts repeat emails. Delete this note before sharing.</p>\n<!-- /wp:paragraph --></div>\n<!-- /wp:group -->\n",
			"post_name": "help-and-faq-2",
			"meta": []
		}
